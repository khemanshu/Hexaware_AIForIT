<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Account Health Management</label>
    <description>Grants field-level security (read/edit) on the Account fields that power Customer Success health and attrition-risk tracking: Health_Status__c, Primary_Risk_Reason__c, Last_Health_Assessment_Date__c, and CSM_Strategic_Notes__c.</description>
    <fieldPermissions>
        <editable>true</editable>
        <field>Account.Health_Status__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Account.Primary_Risk_Reason__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Account.Last_Health_Assessment_Date__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Account.CSM_Strategic_Notes__c</field>
        <readable>true</readable>
    </fieldPermissions>
</PermissionSet>
